<div class="icon-ability-card" data-actor-id="{{actorId}}">
  <div class="icon-ability-card-header">
    <span class="icon-ability-card-name">{{name}}</span>
    {{#if cost}}<span class="icon-ability-card-cost">{{cost}}</span>{{/if}}
  </div>
  {{#if tags.length}}
  <div class="icon-ability-card-tags">
    {{#each tags}}<span class="icon-ability-tag">{{this}}</span>{{/each}}
  </div>
  {{/if}}
  {{#if flavor}}
  <p class="icon-ability-card-flavor">{{flavor}}</p>
  {{/if}}
  {{#if effect}}
  <div class="icon-ability-card-effect">{{{effect}}}</div>
  {{/if}}

  {{!-- To-hit roll: action rating buttons (only for attack abilities) --}}
  {{#if actionRatings.length}}
  <div class="icon-ability-card-rolls">
    <span class="icon-roll-group-label">Roll to Hit</span>
    {{#each actionRatings}}
    <button type="button" class="icon-action-roll-btn" data-value="{{this.value}}" data-label="{{this.label}}" title="{{this.label}} ({{this.value}})">
      {{this.label}} {{this.value}}
    </button>
    {{/each}}
  </div>
  {{/if}}

  {{!-- Damage rolls: inline dice formulas found in the effect text --}}
  {{#if rollableFormulas.length}}
  <div class="icon-ability-card-rolls">
    <span class="icon-roll-group-label">Damage Rolls</span>
    {{#each rollableFormulas}}
    <button type="button" class="icon-roll-btn" data-formula="{{this}}">
      <i class="fas fa-dice-d6"></i> {{this}}
    </button>
    {{/each}}
  </div>
  {{/if}}
</div>
