<div class="icon-ability-card" data-actor-id="{{actorId}}">
  <div class="icon-ability-card-header">
    <span class="icon-ability-card-name">{{name}}</span>
    {{#if cost}}<span class="icon-ability-card-cost">{{cost}}</span>{{/if}}
  </div>
  {{#if tags.length}}
  <div class="icon-ability-card-tags">
    {{#each tags}}<span class="icon-ability-tag">{{this}}</span>{{/each}}
  </div>
  {{/if}}
  {{#if flavor}}
  <p class="icon-ability-card-flavor">{{flavor}}</p>
  {{/if}}
  {{#if effect}}
  <div class="icon-ability-card-effect">{{{effect}}}</div>
  {{/if}}

  {{#if (or isAttack rollableFormulas.length)}}
  <div class="icon-ability-card-rolls">
    {{#if isAttack}}
    <button type="button" class="icon-roll-btn" data-formula="1d10" data-label="Attack">
      <i class="fas fa-dice-d10"></i> Roll to Hit
    </button>
    {{/if}}
    {{#each rollableFormulas}}
    <button type="button" class="icon-roll-btn" data-formula="{{this}}">
      <i class="fas fa-dice-d6"></i> {{this}}
    </button>
    {{/each}}
  </div>
  {{/if}}
</div>
