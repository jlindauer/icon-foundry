<div class="tab tab-content" data-tab="combat" data-group="primary">
<div class="tab-grid-2">

  {{!-- Conditions --}}
  <div class="framed-section">
    <div class="framed-section-header">
      <span class="framed-section-title">{{localize "ICON.Section.Conditions"}}</span>
    </div>
    <div class="framed-section-body">
      <div class="conditions-grid">
        {{#each conditions}}
        <button type="button"
          class="condition-pip {{#if this.active}}active{{/if}}"
          data-action="toggleCondition"
          data-condition-id="{{this.id}}"
          title="{{localize this.label}}">
          <span class="condition-dot"></span>
          {{localize this.label}}
        </button>
        {{/each}}
      </div>
    </div>
  </div>

  {{!-- Progression --}}
  <div class="framed-section">
    <div class="framed-section-header">
      <span class="framed-section-title">Progression</span>
      <span class="framed-section-subtitle">Chapter {{system.progression.level}}</span>
    </div>
    <div class="framed-section-body">
      <div class="rail-stat-row" style="margin-bottom:8px;">
        <span class="rail-stat-label">XP</span>
        <div class="xp-bar-wrap">
          <div class="xp-bar">
            <div class="xp-bar-fill" style="width:{{xpPercent}}%"></div>
          </div>
          <span class="xp-label">{{system.progression.currentXp}}/{{xpForNext}}</span>
        </div>
      </div>
      {{#if isEditable}}
      <div style="display:flex;gap:8px;align-items:center;margin-bottom:8px;">
        <input type="number" name="system.progression.currentXp"
          value="{{system.progression.currentXp}}" min="0"
          style="width:60px;background:transparent;border:1px solid var(--icon-border);color:var(--icon-text);padding:2px 6px;text-align:center;">
        <button type="button" class="btn-xp" data-action="gainXp"
          style="background:var(--icon-accent);color:white;border:none;padding:3px 10px;cursor:pointer;font-size:0.8em;">+1 XP</button>
      </div>
      {{/if}}
      <div style="font-size:0.78em;color:var(--icon-text-muted);margin-bottom:10px;">
        {{localize "ICON.Label.AbilitySlots"}}: {{abilitySlots}} · {{localize "ICON.Label.TalentSlots"}}: {{talentSlots}}
      </div>
      {{!-- Combat XP triggers --}}
      <div style="font-size:0.7em;text-transform:uppercase;letter-spacing:0.08em;color:var(--icon-text-muted);margin-bottom:6px;">Combat XP</div>
      {{#each combatXpTriggers}}
      <label style="display:flex;align-items:flex-start;gap:8px;padding:3px 0;font-size:0.85em;cursor:pointer;">
        <input type="checkbox"
          data-action="checkXpTrigger"
          data-index="{{@index}}"
          data-trigger-type="combat"
          style="margin-top:3px;flex-shrink:0;"
          {{#if (includes ../system.progression.combatXpTriggers @index)}}checked{{/if}}>
        <span style="color:var(--icon-text-sec);">{{this}}</span>
      </label>
      {{/each}}
    </div>
  </div>

  {{!-- Basic Attacks (from jobs) --}}
  {{#if basicAttacks.length}}
  <div class="framed-section span-2">
    <div class="framed-section-header">
      <span class="framed-section-title">{{localize "ICON.Section.BasicAttacks"}}</span>
    </div>
    <div class="framed-section-body">
      {{#each basicAttacks}}
      <details class="expandable">
        <summary>
          <span class="expandable-name">{{this.name}}</span>
          {{#if this.cost}}<span class="expandable-meta">{{this.cost}}</span>{{/if}}
          <button type="button" class="btn-roll"
            data-action="rollAbility"
            data-job-id="{{this.jobId}}"
            data-abil-type="basicAttack"
            title="Post to chat">
            <i class="fas fa-comment-alt"></i>
          </button>
        </summary>
        <div class="expandable-body">
          {{#if this.tags.length}}
          <div class="ability-tags">
            {{#each this.tags}}<span class="ability-tag">{{this}}</span>{{/each}}
          </div>
          {{/if}}
          {{#if this.effect}}<div>{{{this.effect}}}</div>{{/if}}
        </div>
      </details>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- Active Abilities (full width, grouped by tier; limit breaks appended as own group) --}}
  <div class="framed-section span-2">
    <div class="framed-section-header">
      <span class="framed-section-title">{{localize "ICON.Section.ActiveAbilities"}}</span>
      <span style="font-size:0.8em;color:var(--icon-text-muted);">{{totalAbilities}}/{{abilitySlots}}</span>
    </div>
    <div class="framed-section-body">
      {{#if abilityGroups.length}}
      {{#each abilityGroups}}
      <div class="ability-tier-group">
        <div class="ability-tier-heading">{{localize this.label}}</div>
        {{#each this.abilities}}
        <details class="expandable">
          <summary>
            <span class="expandable-name">{{this.name}}</span>
            {{#if this.system.cost}}<span class="expandable-meta">{{this.system.cost}}</span>{{/if}}
            <button type="button" class="btn-roll"
              data-action="rollAbility"
              {{#if (eq this._source "jobAbility")}}
              data-job-id="{{this._jobId}}"
              data-abil-type="{{this._abilType}}"
              {{else}}
              data-item-id="{{this.id}}"
              {{/if}}
              title="Post to chat">
              <i class="fas fa-comment-alt"></i>
            </button>
            {{#if (eq this._source "item")}}
            {{#if ../../isEditable}}
            <button type="button" class="btn-remove" data-action="removeAbility" data-item-id="{{this.id}}"
              title="{{localize 'ICON.Action.Remove'}}">
              <i class="fas fa-times"></i>
            </button>
            {{/if}}
            {{/if}}
          </summary>
          <div class="expandable-body">
            {{#if this.system.tags.length}}
            <div class="ability-tags">
              {{#each this.system.tags}}<span class="ability-tag">{{this}}</span>{{/each}}
            </div>
            {{/if}}
            {{#if this.system.flavor}}<p class="ability-flavor">{{this.system.flavor}}</p>{{/if}}
            {{#if this.system.effect}}<div>{{{this.system.effect}}}</div>
            {{else}}<p style="color:var(--icon-text-muted);font-style:italic;">No effect text.</p>{{/if}}
          </div>
        </details>
        {{/each}}
      </div>
      {{/each}}
      {{else}}
      <p class="empty-hint">{{localize "ICON.Hint.NoAbilities"}}</p>
      {{/if}}
      {{#if isEditable}}
      <div class="drop-hint">{{localize "ICON.Hint.DropAbility"}}</div>
      {{/if}}
    </div>
  </div>

  {{!-- Talents --}}
  <div class="framed-section">
    <div class="framed-section-header">
      <span class="framed-section-title">{{localize "ICON.Section.Talents"}}</span>
      <span style="font-size:0.8em;color:var(--icon-text-muted);">{{selectedTalents.length}}/{{talentSlots}}</span>
    </div>
    <div class="framed-section-body">
      {{#each selectedTalents}}
      <details class="expandable">
        <summary>
          <span style="font-weight:600;font-size:0.9em;flex:1;">{{this.name}}</span>
          {{#if ../isEditable}}
          <button type="button" class="btn-remove" data-action="removeTalent" data-item-id="{{this.id}}"
            title="{{localize 'ICON.Action.Remove'}}" style="margin-left:auto;background:none;border:none;color:var(--icon-text-muted);cursor:pointer;padding:0 4px;">
            <i class="fas fa-times"></i>
          </button>
          {{/if}}
        </summary>
        {{#if this.system.effect}}
        <div class="expandable-body">{{{this.system.effect}}}</div>
        {{else}}
        <div class="expandable-body" style="color:var(--icon-text-muted);font-style:italic;">No description.</div>
        {{/if}}
      </details>
      {{/each}}
      {{#if isEditable}}
      <div class="drop-hint">{{localize "ICON.Hint.DropTalent"}}</div>
      {{/if}}
    </div>
  </div>

  {{!-- Jobs (trait only; basic attacks and limit breaks are shown in their own sections) --}}
  <div class="framed-section">
    <div class="framed-section-header">
      <span class="framed-section-title">{{localize "ICON.Section.Jobs"}}</span>
    </div>
    <div class="framed-section-body">
      {{#each jobs}}
      <details class="expandable">
        <summary>
          <span style="font-weight:600;font-size:0.9em;flex:1;">{{this.name}}</span>
          <span style="font-size:0.78em;color:var(--icon-text-muted);">Lv {{this.level}}</span>
          {{#if this.isMain}}<span style="font-size:0.7em;background:var(--icon-accent-dim);color:white;padding:1px 6px;margin-left:4px;">Main</span>{{/if}}
        </summary>
        <div class="expandable-body">
          {{#if this.trait}}
          <div class="expandable-field">
            <div class="expandable-label">{{this.trait.name}}</div>
            <div>{{{this.trait.effect}}}</div>
          </div>
          {{else}}
          <p style="color:var(--icon-text-muted);font-style:italic;">No trait.</p>
          {{/if}}
        </div>
      </details>
      {{/each}}
      {{#if isEditable}}
      <div class="drop-hint">Drop a job here</div>
      {{/if}}
    </div>
  </div>

</div>
</div>
