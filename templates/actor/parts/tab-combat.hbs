<div class="tab tab-content" data-tab="combat" data-group="primary">
<div class="tab-grid-2">

  {{!-- Resources --}}
  <div class="framed-section">
    <div class="framed-section-header">
      <span class="framed-section-title">Resources</span>
      {{#if isBloodied}}<span style="color:var(--icon-bloodied);font-size:0.75em;font-weight:700;">BLOODIED</span>{{/if}}
      {{#if isInCrisis}}<span style="color:var(--icon-crisis);font-size:0.75em;font-weight:700;">CRISIS</span>{{/if}}
    </div>
    <div class="framed-section-body">
      <div class="resource-block" style="margin-bottom:8px;">
        <label style="font-size:0.7em;text-transform:uppercase;letter-spacing:0.06em;color:var(--icon-text-muted);">{{localize "ICON.Resource.HP"}}</label>
        <div class="resource-bar-wrap">
          <progress class="resource-bar hp-bar" value="{{system.resources.hp.value}}" max="{{system.resources.hp.max}}"></progress>
          <span class="resource-value" data-field="system.resources.hp.value">{{system.resources.hp.value}}</span>
          <span class="resource-sep">/</span>
          <span class="resource-value" data-field="system.resources.hp.max">{{system.resources.hp.max}}</span>
        </div>
      </div>
      <div class="resource-block" style="margin-bottom:8px;">
        <label style="font-size:0.7em;text-transform:uppercase;letter-spacing:0.06em;color:var(--icon-text-muted);">{{localize "ICON.Resource.Vigor"}}</label>
        <div class="resource-bar-wrap">
          <progress class="resource-bar vigor-bar" value="{{system.resources.vigor.value}}" max="{{system.resources.vigor.max}}"></progress>
          <span class="resource-value" data-field="system.resources.vigor.value">{{system.resources.vigor.value}}</span>
          <span class="resource-sep">/</span>
          <span class="resource-value" data-field="system.resources.vigor.max">{{system.resources.vigor.max}}</span>
        </div>
      </div>
    </div>
  </div>

  {{!-- Conditions --}}
  <div class="framed-section">
    <div class="framed-section-header">
      <span class="framed-section-title">{{localize "ICON.Section.Conditions"}}</span>
    </div>
    <div class="framed-section-body">
      <div class="conditions-row" style="display:flex;flex-wrap:wrap;gap:4px;">
        {{#each conditions}}
        <button type="button"
          class="condition-pip {{#if this.active}}active{{/if}} {{#if this.isPositive}}positive{{/if}}"
          data-action="toggleCondition"
          data-condition-id="{{this.id}}"
          title="{{localize this.label}}">
          {{localize this.label}}
        </button>
        {{/each}}
      </div>
    </div>
  </div>

  {{!-- Active Abilities (full width) --}}
  <div class="framed-section span-2">
    <div class="framed-section-header">
      <span class="framed-section-title">{{localize "ICON.Section.ActiveAbilities"}}</span>
      <span style="font-size:0.8em;color:var(--icon-text-muted);">{{activeAbilities.length}}/{{system.abilitySlots}}</span>
    </div>
    <div class="framed-section-body">
      {{#each activeAbilities}}
      <details class="expandable">
        <summary>
          <span style="font-weight:600;font-size:0.9em;flex:1;">{{this.name}}</span>
          {{#if this.system.cost}}<span style="font-size:0.78em;color:var(--icon-text-muted);">{{this.system.cost}}</span>{{/if}}
          {{#if this.system.tier}}<span style="font-size:0.72em;background:var(--icon-border);padding:1px 6px;color:var(--icon-text-sec);">{{this.system.tier}}</span>{{/if}}
          {{#if ../isEditable}}
          <button type="button" class="btn-remove" data-action="removeAbility" data-item-id="{{this.id}}"
            title="{{localize 'ICON.Action.Remove'}}" style="margin-left:auto;background:none;border:none;color:var(--icon-text-muted);cursor:pointer;padding:0 4px;">
            <i class="fas fa-times"></i>
          </button>
          {{/if}}
        </summary>
        {{#if this.system.effect}}
        <div class="expandable-body">{{this.system.effect}}</div>
        {{else}}
        <div class="expandable-body" style="color:var(--icon-text-muted);font-style:italic;">No effect text.</div>
        {{/if}}
      </details>
      {{/each}}
      {{#if isEditable}}
      <div class="drop-hint" style="text-align:center;padding:8px;font-size:0.8em;color:var(--icon-text-muted);border:1px dashed var(--icon-border);margin-top:4px;">{{localize "ICON.Hint.DropAbility"}}</div>
      {{/if}}
    </div>
  </div>

  {{!-- Talents --}}
  <div class="framed-section">
    <div class="framed-section-header">
      <span class="framed-section-title">{{localize "ICON.Section.Talents"}}</span>
      <span style="font-size:0.8em;color:var(--icon-text-muted);">{{selectedTalents.length}}/{{system.talentSlots}}</span>
    </div>
    <div class="framed-section-body">
      {{#each selectedTalents}}
      <details class="expandable">
        <summary>
          <span style="font-weight:600;font-size:0.9em;flex:1;">{{this.name}}</span>
          {{#if ../isEditable}}
          <button type="button" class="btn-remove" data-action="removeTalent" data-item-id="{{this.id}}"
            title="{{localize 'ICON.Action.Remove'}}" style="margin-left:auto;background:none;border:none;color:var(--icon-text-muted);cursor:pointer;padding:0 4px;">
            <i class="fas fa-times"></i>
          </button>
          {{/if}}
        </summary>
        {{#if this.system.effect}}
        <div class="expandable-body">{{this.system.effect}}</div>
        {{else}}
        <div class="expandable-body" style="color:var(--icon-text-muted);font-style:italic;">No description.</div>
        {{/if}}
      </details>
      {{/each}}
      {{#if isEditable}}
      <div class="drop-hint" style="text-align:center;padding:8px;font-size:0.8em;color:var(--icon-text-muted);border:1px dashed var(--icon-border);margin-top:4px;">{{localize "ICON.Hint.DropTalent"}}</div>
      {{/if}}
    </div>
  </div>

  {{!-- Jobs --}}
  <div class="framed-section">
    <div class="framed-section-header">
      <span class="framed-section-title">{{localize "ICON.Section.Jobs"}}</span>
    </div>
    <div class="framed-section-body">
      {{#each jobs}}
      <details class="expandable">
        <summary>
          <span style="font-weight:600;font-size:0.9em;flex:1;">{{this.name}}</span>
          <span style="font-size:0.78em;color:var(--icon-text-muted);">Lv {{this.level}}</span>
          {{#if this.isMain}}<span style="font-size:0.7em;background:var(--icon-accent-dim);color:white;padding:1px 6px;margin-left:4px;">Main</span>{{/if}}
        </summary>
        <div class="expandable-body">
          {{#if this.trait}}
          <div class="expandable-field">
            <div class="expandable-label">Trait</div>
            <div>{{this.trait}}</div>
          </div>
          {{/if}}
          {{#if this.basicAttack}}
          <div class="expandable-field">
            <div class="expandable-label">Basic Attack</div>
            <div>{{this.basicAttack}}</div>
          </div>
          {{/if}}
          {{#if this.limitBreak}}
          <div class="expandable-field">
            <div class="expandable-label">Limit Break</div>
            <div>{{this.limitBreak}}</div>
          </div>
          {{/if}}
        </div>
      </details>
      {{/each}}
      {{#if isEditable}}
      <div style="text-align:center;padding:8px;font-size:0.8em;color:var(--icon-text-muted);border:1px dashed var(--icon-border);margin-top:4px;">Drop a job here</div>
      {{/if}}
    </div>
  </div>

</div>
</div>
